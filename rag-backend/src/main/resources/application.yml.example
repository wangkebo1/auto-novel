spring:
  application:
    name: rag-backend

  # Nacos 服务注册与发现
  cloud:
    compatibility-verifier:
      enabled: false
    nacos:
      discovery:
        server-addr: localhost:8848
        namespace: public
        group: DEFAULT_GROUP

  # 文件上传大小限制
  servlet:
    multipart:
      enabled: true
      max-file-size: 100MB
      max-request-size: 100MB

  # 数据源配置 (PostgreSQL + PGVector)
  datasource:
    url: jdbc:postgresql://localhost:5432/ragdb
    username: ${DB_USERNAME:postgres}
    password: ${DB_PASSWORD:your-db-password}
    driver-class-name: org.postgresql.Driver
    hikari:
      maximum-pool-size: 10
      minimum-idle: 5
      connection-timeout: 30000

  # JPA 配置
  jpa:
    hibernate:
      ddl-auto: none
    show-sql: false
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
        format_sql: true
    defer-datasource-initialization: false

  # Flyway 数据库版本管理
  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true
    baseline-version: 0

  # Spring AI 配置
  ai:
    openai:
      api-key: ${OPENAI_API_KEY:your-openai-api-key}
      base-url: ${OPENAI_BASE_URL:https://api.edgefn.net}
      chat:
        options:
          model: DeepSeek-V3
          temperature: 0.1
          max-tokens: 4096

    ollama:
      chat:
        enabled: false

    vectorstore:
      pgvector:
        enabled: true
        initialize-schema: true
        dimensions: 768
        distance-type: COSINE_DISTANCE
        index-type: HNSW
        schema-name: public
        table-name: vector_store

server:
  port: 8084

# 自定义配置
rag:
  upload:
    path: ${RAG_UPLOAD_PATH:./uploads}
    allowed-extensions: pdf,doc,docx,xls,xlsx,txt,md
  retrieval:
    top-k: 5
    similarity-threshold: 0.5
  llm:
    timeout-seconds: 300
  chunk:
    size: 512
    min-size: 128
  novel:
    ai:
      model: MiniMax-M2.5

  chat-vision:
    base-url: ${CHAT_VISION_BASE_URL:https://meta.tangarcin.de}
    api-key: ${CHAT_VISION_API_KEY:your-chat-vision-api-key}
    model: gpt-5.4
    timeout-seconds: 45

logging:
  level:
    com.rag: DEBUG
    org.springframework.ai: INFO
    org.hibernate.SQL: WARN

# JWT 配置
jwt:
  secret: ${JWT_SECRET:your-jwt-secret-key-at-least-256-bits}
  expiration: 86400

# Kling 视频生成 API 配置
kling:
  api:
    base-url: https://api.qnaigc.com/v1
    key: ${KLING_API_KEY:your-kling-api-key}
